class hewan: 
    def __init__(self, nama, jenis):
        self.nama = nama
        self.jenis = jenis

harimau = hewan("sumatera", "jawa")
ayam = hewan("sulawesi", "bali")
orangutan = hewan("kalimatan", "sunda")

print(harimau.nama)
print(harimau.jenis)
print(ayam.nama)
print(ayam.jenis)
print(orangutan.nama)
print(orangutan.jenis)
