class MataKuliah:
    def __init__(self, kelas, nama_mk, jumlah_sks, dosen_pengampu, ruang_kelas):
        self.kelas = kelas
        self.nama_mk = nama_mk
        self.jumlah_sks = jumlah_sks
        self.dosen_pengampu = dosen_pengampu
        self.ruang_kelas = ruang_kelas

    def tampilkanKelas(self):
        print("Kelas: ", self.kelas)
    def tampilkanNamaMK(self):
        print("Nama Mata Kuliah: ", self.nama_mk)
    def tampilkanSKS(self):
        print("Jumlah SKS: ", self.jumlah_sks)
    def tampilkanDosen(self):
        print("Dosen Pengampu: ", self.dosen_pengampu)
    def tampilkanRuang(self):
        print("Ruang Kelas: ", self.ruang_kelas)

