#class induk
class hewan:
    def __init__(self, nama, jenis):
        self.nama = nama
        self.jenis = jenis

    def bersuara(self):
        pass

    def jumlah_kaki(self):
        print("berkaki empat")

    def jenis_makanan(self):
        pass

#class anak 1
class anjing(hewan):
    def bersuara(self):
        print("woof!")
    
    def jenis_makanan(self):
        print("daging")

class kucing(hewan):
    def bersuara(self):
        print("meong!")
    
    def jenis_makanan(self):
        print("wiskas")

class sapi(hewan):
    def bersuara(self):
        print("moo!")
    
    def jenis_makanan(self):
        print("rumput")

# Instansiasi Objek
hewan1 = anjing("imam", "buldog")
hewan2 = kucing("arill", "anggora")
hewan3 = sapi("radin", "hitam putih")

# Output
print("sifat anjing: ")
hewan1.bersuara()
hewan1.jumlah_kaki()
hewan1.jenis_makanan()

print("sifat kucing: ")
hewan2.bersuara()
hewan2.jumlah_kaki()
hewan2.jenis_makanan()

print("sifat sapi: ")
hewan3.bersuara()
hewan3.jumlah_kaki()
hewan3.jenis_makanan()
